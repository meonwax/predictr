# predictr environment configuration
#
# Copy this file to `.env` for local development:
#     cp .env.example .env
#
# Compose automatically loads `.env` and substitutes ${VAR} references in
# both docker-compose.yml and docker-compose.override.yml.
#
# Production deployments should NOT use this file - populate the variables
# however the host environment expects (systemd unit, CI/CD secrets, etc.).
# ===========================================================================

# ---------------------------------------------------------------------------
# Compose layout
# ---------------------------------------------------------------------------
# The repo ships two files:
#   docker-compose.yml          prod-ready baseline (persistent volume, no
#                               mailhog, no DB port exposure, AUTO_SEED off)
#   docker-compose.override.yml auto-merged on top in dev: tmpfs (ephemeral)
#                               DB, mailhog, exposed postgres port, AUTO_SEED
#
# Dev:   docker compose up -d
# Prod:  docker compose -f docker-compose.yml up -d

# ---------------------------------------------------------------------------
# Host port bindings (default to 127.0.0.1 so nothing leaks publicly)
# ---------------------------------------------------------------------------
APP_BIND=127.0.0.1:8000
POSTGRES_BIND=127.0.0.1:5432
MAILHOG_BIND=127.0.0.1:8025
ADMINER_BIND=127.0.0.1:8081

# ---------------------------------------------------------------------------
# Backups (postgres-backup sidecar, prod only)
# ---------------------------------------------------------------------------
# Host directory where the daily pg_dump files are written. Bind-mounted
# into the postgres-backup container at /backups. Point your host-level
# backup tool (Borg / restic / rsync / VPS snapshots) at this directory.
BACKUP_DIR=./backups
# UTC hour (0-23) to run the daily backup at. The default 4 = 04:00 UTC =
# 06:00 CEST during the WC 2026 tournament window (June/July, all CEST).
BACKUP_HOUR_UTC=4
# Optional: write one immediate backup when the container starts, useful
# to sanity-check that pg_dump works right after deploying.
BACKUP_ON_STARTUP=0

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Session cookie signing key - MUST be a long random value in production
# (e.g. `python -c 'import secrets; print(secrets.token_urlsafe(48))'`).
SESSION_SECRET=dev-secret-change-me-in-production

# Toggle FastAPI debug mode and SQLAlchemy statement logging.
DEBUG=true
SQL_ECHO=false

# Application log level (root logger for the `app.*` hierarchy).
# Accepts DEBUG / INFO / WARNING / ERROR / CRITICAL (case-insensitive).
# The compose stack picks sensible defaults per profile if this is unset:
#   - docker-compose.yml           (prod) defaults to INFO
#   - docker-compose.override.yml  (dev)  defaults to DEBUG
# Set this in .env only when you want to override either of those.
LOG_LEVEL=DEBUG

# Postgres credentials used by the postgres service AND by the app's
# DATABASE_URL. Changing this requires recreating the postgres volume.
POSTGRES_PASSWORD=predictr

# Migrations & seed (handled in docker/entrypoint.sh)
RUN_MIGRATIONS=1
# AUTO_SEED runs `python -m app.seed --if-empty seeds/wc2026.sql` on boot.
# It's an idempotent no-op on an already-populated DB, so leaving it on in
# dev means a fresh tmpfs database is always pre-loaded with WC 2026 data.
AUTO_SEED=1

# ---------------------------------------------------------------------------
# Mail
# ---------------------------------------------------------------------------
# In dev the override file points this at the mailhog service (port 1025,
# UI on $MAILHOG_BIND). In production, set this to your real SMTP relay.
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=false
MAIL_SENDER=noreply@predictr.local
